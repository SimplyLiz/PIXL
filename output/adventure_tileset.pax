[pax]
version = "2.0"
name    = "adventure_overworld"
theme   = "adventure"

[theme.adventure]
palette          = "overworld"
scale            = 2
canvas           = 16
max_palette_size = 16
light_source     = "top-left"

[theme.adventure.roles]
void   = "."
bg     = "#"
fg     = "+"
accent = "o"
danger = "r"
shadow = "s"
life   = "g"
hi     = "G"

[theme.adventure.constraints]
fg_brighter_than_bg         = true
shadow_darker_than_bg       = true
accent_hue_distinct_from_bg = true
max_colors_per_tile         = 16

# Palette: overworld adventure — vibrant greens, warm earth, cool stone
# Derived from reference: Blossom Tales / Zelda-like top-down RPG
[palette.overworld]
"." = "#00000000"
"s" = "#2a1a0a"
"#" = "#5a3a1a"
"+" = "#8a6a3a"
"h" = "#c0a060"
"w" = "#e8d8b0"
"g" = "#1a6a20"
"G" = "#40a840"
"L" = "#70d050"
"~" = "#607888"
"B" = "#788a98"
"W" = "#98aab8"
"o" = "#e8c040"
"r" = "#c83838"
"p" = "#e880a0"
"k" = "#101008"

# --- Stamps ---

[stamp.cobble_4x4]
palette = "overworld"
size    = "4x4"
grid = '''
~BWB
B~~B
W~B~
BWB~
'''

[stamp.grass_4x4]
palette = "overworld"
size    = "4x4"
grid = '''
gGgG
GgLg
gGgG
GgGg
'''

[stamp.earth_4x4]
palette = "overworld"
size    = "4x4"
grid = '''
#s+#
s#+#
#s+#
+#s+
'''

# ===================================================================
# FLOOR TILES — walkable ground
# ===================================================================

# Grass: lush green field, base walkable terrain
# Blossom Tales style — dominant mid-green, organic tuft marks, sparse highlights
[tile.grass]
palette    = "overworld"
size       = "16x16"
edge_class = { n = "grass", e = "grass", s = "grass", w = "grass" }
tags       = ["floor", "grass", "exterior"]
weight     = 5.0
semantic   = { affordance = "walkable", collision = "none", tags = { biome = "overworld" } }
grid = '''
GGGGGgGGGGGGGGgG
GGGGGGGGGGGGGGGG
GGgGGGGGGGLGGGGG
GGGGGGGGGGgGGGgG
GGGGGLGGGGGGGGgG
GGGGGGGGGGGGGGGG
GLGGGGGGgGGGGGGG
GgGGGGGGGGGGGgGG
GgGGGGGGGGGGGGGG
GGGGGGGGGGGgGGGG
GGGGGgGGLGGGGGGG
GGGGGGGGgGGGGGGg
GGgGGGGGGGGGGGGG
GGGGGGGGGGGGLGgG
GGGGGGgGGGGGGGGG
GGGGGGGGGGgGGGGG
'''

# Grass with white flowers scattered
[tile.grass_flowers_white]
palette    = "overworld"
size       = "16x16"
edge_class = { n = "grass", e = "grass", s = "grass", w = "grass" }
tags       = ["floor", "grass", "flowers", "exterior"]
weight     = 1.5
semantic   = { affordance = "walkable", collision = "none", tags = { biome = "overworld" } }
grid = '''
GGGGGgGGGGGGGGGG
GGGGGGGGGGwGGGgG
GGgGGGGGGGGGGGGG
GGGGGGLGGGGGGGgG
GGGGGGgGGGGwGGGG
GGwGGGGGGGGGGGGG
GGGGGGGGgGGGGGGG
GLGGGGGGGGGGwGGG
GgGGGwGGGGGGGGGG
GGGGGGGGGGgGGGGG
GGGGGGGGGGGGGGGg
GGGGgGGGGGGGGGGG
GGGGGGGGLGGGwGGG
GGwGGGGGgGGGGGgG
GGGGGGGGGGGGGGGG
GGGGGgGGGGGGGGGG
'''

# Grass with pink flowers
[tile.grass_flowers_pink]
palette    = "overworld"
size       = "16x16"
edge_class = { n = "grass", e = "grass", s = "grass", w = "grass" }
tags       = ["floor", "grass", "flowers", "exterior"]
weight     = 1.0
semantic   = { affordance = "walkable", collision = "none", tags = { biome = "overworld" } }
grid = '''
GGGGGGGGGGGgGGGG
GGGGgGGGGGGGGGGG
GGGGGGGGpGGGGGGG
GGpGGGGGGGGGGGgG
GGGGGGGGGGGGpGGG
GGGGGLGGGGGGGGGg
GGGGGgGGGGGGGGGG
GGGGGGGGGpGGGGGG
GGgGGGGGGGGGGGGG
GGGGGGpGGGGGGGGG
